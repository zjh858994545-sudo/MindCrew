# MindCrew local environment example.
# Copy to .env locally if you need docker-compose or shell based env loading.
# Do not commit real secrets.

# LLM provider: Aliyun Bailian / DashScope OpenAI-compatible API
BAILIAN_API_KEY=replace-with-your-bailian-api-key

# Optional web search. Leave empty to disable Tavily-backed search.
TAVILY_API_KEY=
MINDCREW_WEB_SEARCH_ENABLED=false

# MySQL
MYSQL_DATABASE=docmind
MYSQL_USER=root
MYSQL_PASSWORD=replace-with-local-mysql-password
MYSQL_ROOT_PASSWORD=replace-with-local-root-password

# Redis
REDIS_PASSWORD=

# MinIO local object storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=replace-with-local-minio-password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=replace-with-local-minio-password

# Aliyun OSS, only required when storage.type=oss
OSS_ENDPOINT=
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# Application secrets. Use long random values in production.
JWT_SECRET=replace-with-long-random-jwt-secret
CRYPTO_MASTER_KEY=replace-with-32-chars-or-longer-random-key

# Optional ASR/BSS provider
BSS_ACCESS_KEY=
BSS_SECRET_KEY=
