# =====================================================================
# MindCrew · Docker 部署环境变量模板
# 用法：
#   cp .env.docker.example .env
#   vim .env                  # 至少把 BAILIAN_API_KEY 填了
#   docker compose up -d --build
#
# 提示：本文件可以安全提交到 git；.env 含真实密钥，务必 gitignore
# =====================================================================

# ───────────────────────────── 必填 ─────────────────────────────
# 阿里云百炼 API Key · 申请: https://bailian.console.aliyun.com/?apiKey=1
BAILIAN_API_KEY=replace-with-your-bailian-api-key

# ───────────────────────────── 可选 ─────────────────────────────
# Tavily Web 搜索 · https://app.tavily.com 注册免费 1000 次/月
TAVILY_API_KEY=
MINDCREW_WEB_SEARCH_ENABLED=true

# ───────────────────────── 端口（默认值） ──────────────────────
FRONTEND_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379
MILVUS_PORT=19530
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ───────────────────────── 凭证（开发可保持默认） ──────────────────────
MYSQL_ROOT_PASSWORD=root
REDIS_PASSWORD=
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ───────────────────────── 存储模式 ──────────────────────
# minio · 本地 MinIO 容器（默认，推荐）
# oss   · 阿里云 OSS（需填下方 OSS_* 参数）
STORAGE_TYPE=minio

# ─── OSS（STORAGE_TYPE=oss 时必填） ───
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_REGION=cn-hangzhou
OSS_BUCKET=mindcrew-prod
OSS_ACCESS_KEY=
OSS_SECRET_KEY=

# ───────────────────────── 安全（生产必改） ──────────────────────
# 32 字符以上随机串：openssl rand -base64 48
CRYPTO_MASTER_KEY=please-change-me-in-production-32chars-min
JWT_SECRET=MindCrew2026SecretKeyForJWTTokenGenerationPleaseChangeInProduction

# ───────────────────────── JVM 调优 ──────────────────────
JAVA_OPTS=-Xms512m -Xmx2048m -XX:+UseG1GC

# ───────────────────────── 阿里云账单（可选） ──────────────────────
BSS_ENABLED=false
BSS_ACCESS_KEY=
BSS_SECRET_KEY=
